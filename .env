# ─────────────────────────────────────────────
# Pitch Visualizer — Environment Configuration
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── Open-source LLM for prompt engineering (use at least one path) ──
# Option A — Ollama (local): https://ollama.com — install, then: ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest

# Option B — Hugging Face Inference API (cloud, open models on the Hub)
# Create a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here
# Instruct model for text (Mistral-style [INST] template in code)
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Prefer which provider when both are configured: auto | ollama | huggingface
LLM_PROVIDER=auto

# ── Image generation (optional; otherwise SVG placeholders) ──
# Option 1 — Stability AI SDXL
STABILITY_API_KEY="Enter your Stability API key here"

# Option 2 — Hugging Face diffusers model via Inference API (same HF_TOKEN)
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Option 3 — OpenAI DALL-E 3
OPENAI_API_KEY="Enter your OpenAI API key here"
# Server (optional)
PORT=5000
